# Cloudflare 配置
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ACCOUNT_ID=your_account_id

# D1 数据库
D1_DATABASE_ID=your_d1_database_id
D1_DATABASE_NAME=geekron-cms-db

# R2 存储桶
R2_BUCKET_NAME=geekron-cms-files
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key

# 环境变量
NODE_ENV=development
ENVIRONMENT=local

# API 配置
API_BASE_URL=http://localhost:8787
API_PORT=8787

# 数据库配置 (本地开发用 PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/geekron_cms
REDIS_URL=redis://localhost:6379

# Supabase 配置 (可选)
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

# 认证配置
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRES_IN=7d
SESSION_SECRET=your_session_secret

# 邮件配置 (可选)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@geekron-cms.com

# 存储配置
STORAGE_TYPE=local # local, r2, s3, oss
STORAGE_PATH=./uploads

# 日志配置
LOG_LEVEL=debug # debug, info, warn, error
LOG_FORMAT=json # json, pretty

# 功能开关
ENABLE_SIGNUP=true
ENABLE_TENANT_CREATION=true
MAX_TENANTS_PER_USER=5
