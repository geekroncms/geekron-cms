{
  "name": "geekron-cms",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"bun run dev:server\" \"bun run dev:admin\"",
    "dev:server": "bun --watch packages/server/src/index.ts",
    "dev:admin": "bun run --filter @geekron-cms/admin dev",
    "build": "bun run build:server && bun run build:admin",
    "build:server": "bun build packages/server/src/index.ts --outdir dist/server --target bun",
    "build:admin": "bun run --filter @geekron-cms/admin build",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:production": "wrangler deploy --env production",
    "db:migrate": "bun run packages/server/src/db/migrate.ts",
    "db:seed": "bun run packages/server/src/db/seed.ts",
    "db:reset": "./scripts/reset-db.sh",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "lint": "eslint packages/**/*.{ts,vue}",
    "lint:fix": "eslint packages/**/*.{ts,vue} --fix",
    "format": "prettier --write \"packages/**/*.{ts,vue,json,md}\"",
    "format:check": "prettier --check \"packages/**/*.{ts,vue,json,md}\"",
    "typecheck": "tsc --noEmit",
    "init": "./scripts/init.sh",
    "version": "./scripts/version.sh",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260312.1",
    "@playwright/test": "^1.58.2",
    "@types/bun": "latest",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-vue": "9.32.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.0",
    "prettier-plugin-organize-imports": "^3.2.0",
    "typescript": "^5.4.0",
    "vue-eslint-parser": "9.4.3",
    "wrangler": "^4.72.0"
  },
  "lint-staged": {
    "*.{ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "@types/pg": "^8.18.0",
    "pg": "^8.20.0"
  }
}
