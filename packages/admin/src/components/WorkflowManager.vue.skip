  margin-bottom: 8px;
}

.btn-remove {
  background: none;
  border: 1px solid #e5e7eb;
  padding: 4px 12px;
  border-radius: 4px;
  color: #6b7280;
  cursor: pointer;
  font-size: 13px;
}

.btn-remove:hover {
  background: #fee2e2;
  border-color: #f56565;
  color: #f56565;
}

.actions {
  display: flex;
  justify-content: flex-end;
  gap: 12px;
  margin-top: 24px;
}

.btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  padding: 10px 20px;
  border-radius: 6px;
  font-weight: 500;
  cursor: pointer;
  transition: transform 0.2s, box-shadow 0.2s;
}

.btn-primary:hover:not(:disabled) {
  transform: translateY(-2px);
  box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
}

.btn-primary:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.btn-secondary {
