<template>
  <div class="workflow-management">
    <div class="header">
      <h1 class="title">工作流管理</h1>
      <p class="subtitle">配置内容审核流程和状态转换</p>
    </div>

    <!-- 加载状态 -->
    <div v-if="loading" class="loading-container">
      <div class="loading-spinner"></div>
      <p>加载中...</p>
    </div>

    <!-- 错误状态 -->
    <div v-else-if="error" class="error-container">
      <p class="error-text">{{ error }}</p>
      <button @click="loadWorkflow" class="btn-retry">重试</button>
    </div>

    <!-- 工作流配置 -->
    <div v-else class="content">
      <!-- 工作流状态列表 -->
      <div class="card">
        <div class="card-header">
          <h2 class="card-title">工作流状态</h2>
          <button @click="addState" class="btn-primary">添加状态</button>
        </div>
        <div class="states-list">
          <div
            v-for="(state, index) in workflow.states"
            :key="state.id"
            class="state-item"
            :style="{ borderLeftColor: state.color }"
          >
            <div class="state-info">
              <span class="state-name">{{ state.name }}</span>
              <span class="state-id">{{ state.id }}</span>
              <span v-if="state.description" class="state-desc">{{ state.description }}</span>
            </div>
            <div class="state-actions">
              <button @click="editState(index)" class="btn-icon">✏️</button>
              <button @click="removeState(index)" class="btn-icon danger">🗑️</button>
            </div>
          </div>
        </div>
      </div>

      <!-- 工作流转换 -->
      <div class="card">
        <div class="card-header">
          <h2 class="card-title">状态转换</h2>
          <button @click="addTransition" class="btn-primary">添加转换</button>
        </div>
        <div class="transitions-list">
          <div v-for="(transition, index) in workflow.transitions" :key="index" class="transition-item">
            <div class="transition-flow">
              <span class="state-badge">{{ transition.from }}</span>
              <span class="arrow">→</span>
              <span class="action-badge">{{ transition.action }}</span>
              <span class="arrow">→</span>
              <span class="state-badge">{{ transition.to }}</span>
            </div>
            <div v-if="transition.description" class="transition-desc">{{ transition.description }}</div>
            <button @click="removeTransition(index)" class="btn-remove">移除</button>
          </div>
        </div>
      </div>

      <!-- 操作按钮 -->
      <div class="actions">
        <button @click="resetToDefault" class="btn-secondary">恢复默认</button>
        <button @click="saveWorkflow" :disabled="saving" class="btn-primary">
          {{ saving ? '保存中...' : '保存配置' }}
        </button>
      </div>
    </div>

    <!-- 状态编辑弹窗 -->
    <div v-if="showStateModal" class="modal-overlay" @click="closeStateModal">
      <div class="modal" @click.stop>
        <h3>{{ editingStateIndex !== null ? '编辑状态' : '添加状态' }}</h3>
        <div class="form-group">
          <label>ID</label>
          <input v-model="currentState.id" type="text" class="input" placeholder="例如：draft" />
        </div>
        <div class="form-group">
          <label>名称</label>
          <input v-model="currentState.name" type="text" class="input" placeholder="例如：草稿" />
        </div>
        <div class="form-group">
          <label>颜色</label>
          <input v-model="currentState.color" type="color" class="input-color" />
          <span class="color-preview" :style="{ backgroundColor: currentState.color }"></span>
        </div>
        <div class="form-group">
          <label>描述</label>
          <input v-model="currentState.description" type="text" class="input" placeholder="状态描述" />
        </div>
        <div class="modal-actions">
          <button @click="closeStateModal" class="btn-secondary">取消</button>
          <button @click="confirmState" class="btn-primary">确定</button>
        </div>
      </div>
    </div>

    <!-- 转换编辑弹窗 -->
    <div v-if="showTransitionModal" class="modal-overlay" @click="closeTransitionModal">
      <div class="modal" @click.stop>
        <h3>添加状态转换</h3>
        <div class="form-group">
          <label>从状态</label>
          <select v-model="currentTransition.from" class="input">
            <option v-for="state in workflow.states" :key="state.id" :value="state.id">
              {{ state.name }}
            </option>
          </select>
        </div>
        <div class="form-group">
          <label>动作</label>
          <input v-model="currentTransition.action" type="text" class="input" placeholder="例如：submit" />
        </div>
        <div class="form-group">
          <label>到状态</label>
          <select v-model="currentTransition.to" class="input">
            <option v-for="state in workflow.states" :key="state.id" :value="state.id">
              {{ state.name }}
            </option>
          </select>
        </div>
        <div class="form-group">
          <label>描述</label>
          <input v-model="currentTransition.description" type="text" class="input" placeholder="转换描述" />
        </div>
        <div class="modal-actions">
          <button @click="closeTransitionModal" class="btn-secondary">取消</button>
          <button @click="confirmTransition" class="btn-primary">确定</button>
        </div>
      </div>
    </div>
  </div>
</template>

<script setup lang="ts">
import { ref, reactive, onMounted } from 'vue'
import { workflowApi } from '../../api/workflow'
const getWorkflowConfig = workflowApi.getConfig
const saveWorkflowConfig = workflowApi.saveConfig

interface WorkflowState {
  id: string
  name: string
  color: string
  description?: string
}

interface WorkflowTransition {
  from: string
  to: string
  action: string
  description?: string
}

const props = defineProps<{
  collectionId: string
}>()

const loading = ref(true)
const error = ref<string | null>(null)
const saving = ref(false)
const workflow = reactive({
  states: [] as WorkflowState[],
  transitions: [] as WorkflowTransition[],
})

// 状态编辑
const showStateModal = ref(false)
const editingStateIndex = ref<number | null>(null)
const currentState = reactive<WorkflowState>({
  id: '',
  name: '',
  color: '#667eea',
  description: '',
})

// 转换编辑
const showTransitionModal = ref(false)
const currentTransition = reactive<WorkflowTransition>({
  from: '',
  action: '',
  to: '',
  description: '',
})

// 加载工作流配置
async function loadWorkflow() {
  loading.value = true
  error.value = null
  try {
    const config = await getWorkflowConfig(props.collectionId)
    workflow.states = config.states
    workflow.transitions = config.transitions
  } catch (e: any) {
    error.value = e.message || '加载失败'
  } finally {
    loading.value = false
  }
}

// 添加状态
function addState() {
  editingStateIndex.value = null
  currentState.id = ''
  currentState.name = ''
  currentState.color = '#667eea'
  currentState.description = ''
  showStateModal.value = true
}

// 编辑状态
function editState(index: number) {
  editingStateIndex.value = index
  const state = workflow.states[index]
  currentState.id = state.id
  currentState.name = state.name
  currentState.color = state.color
  currentState.description = state.description || ''
  showStateModal.value = true
}

// 确认状态
function confirmState() {
  if (!currentState.id || !currentState.name) {
    alert('请填写完整的状态信息')
    return
  }

  if (editingStateIndex.value !== null) {
    workflow.states[editingStateIndex.value] = { ...currentState }
  } else {
    workflow.states.push({ ...currentState })
  }
  closeStateModal()
}

// 关闭状态弹窗
function closeStateModal() {
  showStateModal.value = false
  editingStateIndex.value = null
}

// 移除状态
function removeState(index: number) {
  if (confirm('确定要删除这个状态吗？相关的转换也会被删除。')) {
    workflow.states.splice(index, 1)
  }
}

// 添加转换
function addTransition() {
  if (workflow.states.length < 2) {
    alert('至少需要两个状态才能创建转换')
    return
  }
  currentTransition.from = workflow.states[0].id
  currentTransition.to = workflow.states[1].id
  currentTransition.action = ''
  currentTransition.description = ''
  showTransitionModal.value = true
}

// 确认转换
function confirmTransition() {
  if (!currentTransition.from || !currentTransition.to || !currentTransition.action) {
    alert('请填写完整的转换信息')
    return
  }
  workflow.transitions.push({ ...currentTransition })
  closeTransitionModal()
}

// 关闭转换弹窗
function closeTransitionModal() {
  showTransitionModal.value = false
}

// 移除转换
function removeTransition(index: number) {
  workflow.transitions.splice(index, 1)
}

// 恢复默认工作流
function resetToDefault() {
  if (confirm('确定要恢复默认工作流配置吗？')) {
    workflow.states = [
      { id: 'draft', name: '草稿', color: 'gray', description: '内容正在编辑中' },
      { id: 'pending', name: '待审核', color: 'yellow', description: '等待审核通过' },
      { id: 'published', name: '已发布', color: 'green', description: '内容已发布' },
      { id: 'archived', name: '已归档', color: 'blue', description: '内容已归档' },
    ]
    workflow.transitions = [
      { from: 'draft', to: 'pending', action: 'submit', description: '提交审核' },
      { from: 'pending', to: 'published', action: 'approve', description: '审核通过' },
      { from: 'pending', to: 'draft', action: 'reject', description: '拒绝并返回草稿' },
      { from: 'published', to: 'archived', action: 'archive', description: '归档内容' },
      { from: 'archived', to: 'draft', action: 'restore', description: '恢复为草稿' },
    ]
  }
}

// 保存工作流配置
async function saveWorkflow() {
  if (workflow.states.length === 0) {
    alert('至少需要一个状态')
    return
  }

  saving.value = true
  try {
    await saveWorkflowConfig({
      collectionId: props.collectionId,
      states: workflow.states,
      transitions: workflow.transitions,
    })
    alert('工作流配置已保存')
  } catch (e: any) {
    alert('保存失败：' + (e.message || '未知错误'))
  } finally {
    saving.value = false
  }
}

onMounted(() => {
  loadWorkflow()
})
</script>

