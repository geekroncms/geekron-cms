<template>
  <div class="workflow-page">
    <div class="container">
      <!-- 页面头部 -->
      <div class="page-header">
        <div class="breadcrumb">
          <router-link to="/collections" class="breadcrumb-link">集合列表</router-link>
          <span class="breadcrumb-separator">/</span>
          <span class="breadcrumb-link">{{ collectionName }}</span>
          <span class="breadcrumb-separator">/</span>
          <span class="breadcrumb-current">工作流管理</span>
        </div>
        <h1 class="page-title">工作流管理</h1>
        <p class="page-description">
          配置内容审核流程，管理状态转换和审核规则
        </p>
      </div>

      <!-- 集合选择 -->
      <div v-if="!collectionId" class="collection-selector">
        <div class="card">
          <h2 class="card-title">选择集合</h2>
          <p class="card-description">请选择要配置工作流的集合</p>
          <select v-model="selectedCollection" class="select">
            <option value="">-- 请选择集合 --</option>
            <option v-for="collection in collections" :key="collection.id" :value="collection.id">
              {{ collection.displayName }} ({{ collection.name }})
            </option>
          </select>
          <button @click="goToWorkflow" class="btn-primary" :disabled="!selectedCollection">
            进入工作流管理
          </button>
        </div>
      </div>

      <!-- 工作流管理器 -->
      <WorkflowManager v-else :collectionId="collectionId" />

      <!-- 返回按钮 -->
      <div class="back-button">
        <button @click="backToCollections" class="btn-secondary">← 返回集合列表</button>
      </div>
    </div>
  </div>
</template>

<script setup lang="ts">
import { ref, computed, onMounted } from 'vue'
import { useRouter, useRoute } from 'vue-router'
import WorkflowManager from '../components/WorkflowManager.vue'
import { getCollections } from '../api/collections'

const router = useRouter()
const route = useRoute()

const collections = ref<any[]>([])
const selectedCollection = ref('')
const collectionName = ref('')

const collectionId = computed(() => {
  return route.query.collectionId as string
})

// 加载集合列表
async function loadCollections() {
  try {
    const data = await getCollections()
    collections.value = data
  } catch (e: any) {
    console.error('加载集合失败:', e)
  }
}

// 跳转到工作流管理
function goToWorkflow() {
  if (selectedCollection.value) {
    router.push({
      name: 'workflow',
      query: { collectionId: selectedCollection.value },
    })
  }
}

// 返回集合列表
function backToCollections() {
  router.push('/collections')
}

onMounted(() => {
  loadCollections()
})
</script>

